<!-- ===== Footer ===== -->
<footer class="site-footer bg-blaga-100/50 dark:bg-blaga-950">
  <div class="inner">

	<div class="grid gap-6 lg:grid-cols-[minmax(0,1.2fr)_minmax(0,0.9fr)]">
		
	  <div class="space-y-2">
		<h2 class="text-xl font-semibold">{{ site.name }}</h2>
		<p class="site info">
		{{ site.description }}
		</p>

		<ul class="space-y-1">
			<li><span class="font-semibold">Email: </span>{{ site.email }}</li>
			<li><span class="font-semibold">Phone: </span>{{ site.phone }}</li>
			<li><span class="font-semibold">Location: </span>{{ site.location }}</li>
		</ul>
	  </div>

	  	<div class="grid gap-6 sm:grid-cols-2">

			<div class="footer-menu-1">
			
				<h3 class="font-bold mb-2">Quick Link</h3>

				<ul class="space-y-1">
					<li><a href="#">Quick Link</a></li>
					<li><a href="#">Home</a></li>
					<li><a href="#">About</a></li>
					<li><a href="#">Product</a></li>
					<li><a href="#">Blog</a></li>
					<li><a href="#">FAQ</a></li>
				</ul>
			</div>
			
			<div class="footer-menu-2">

				<h3 class="font-bold mb-2">Information</h3>

				<ul class="space-y-1">
					<li><a href="#">Affiliate Program</a></li>
					<li><a href="#">Terms and Conditions</a></li>
					<li><a href="#">Privacy Policy</a></li>
					<li><a href="#">Join our Team</a></li>
					<li><a href="#">Legal Notice</a></li>
				</ul>

			</div>
		</div>

	</div>

	<div class="mt-8 border-t border-blaga-200 pt-6 text-sm  dark:border-blaga-800">
	  <p>&copy; {{ site.year }} {{ site.name }}. {{ site.footerText }}</p>
	</div>

  </div>
</footer>
<!-- ===== /Footer ===== -->