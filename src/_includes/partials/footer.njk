<!-- ===== Footer ===== -->
<footer class="site-footer bg-blaga-100/50">
  <div class="inner">

	<div class="grid gap-6 lg:grid-cols-[minmax(0,1.2fr)_minmax(0,0.9fr)]">
		
	  <div class="border">
		<h2 class="text-lg font-semibold text-slate-900">{{ site.name }}</h2>
		<p class="site info">
		{{ site.description }}
		</p>
	  </div>

	  	<div class="grid gap-6 sm:grid-cols-2">

		  <div class="space-y-2 text-sm text-slate-600 border">
			  <p><strong class="text-slate-900">Email:</strong> {{ site.email }}</p>
			  <p><strong class="text-slate-900">Phone:</strong> {{ site.phone }}</p>
			  <p><strong class="text-slate-900">Location:</strong> {{ site.location }}</p>
			</div>
			
			<div class="border">
				<ul>
					<li>Menu 1</li>
					<li>Menu 2</li>
				</ul>
			</div>
		</div>

	</div>

	<div class="mt-8 border-t border-slate-200 pt-6 text-sm text-slate-500">
	  <p>&copy; {{ site.year }} {{ site.name }}. {{ site.footerText }}</p>
	</div>

  </div>
</footer>
<!-- ===== /Footer ===== -->