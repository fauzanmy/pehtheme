<!-- ===== Hero Section ===== -->
<section class="hero bg-blaga-100/50">
  <div class="inner">

	  <p class="mb-4 text-sm font-semibold uppercase tracking-wide text-blue-600">
		{{ site.tagline }}
	  </p>
	  <h1 class="section-title text-4xl font-bold leading-tight lg:text-5xl text-blue-700/80">
		{{ site.description }}
	  </h1>
	  <p class="section-subtitle mt-3 text-xl leading-relaxed text-blue-600 lg:text-2xl">
		{{ site.lead }}
	  </p>

  </div>
</section>
<!-- ===== /Hero Section ===== -->