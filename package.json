{
  "name": "pehtheme",
  "version": "2.0.0-dev",
  "private": true,
  "description": "Pehtheme HTML template powered by Vite, Tailwind CSS, and Nunjucks.",
  "type": "module",
  "packageManager": "pnpm@11.8.0",
  "scripts": {
    "predev": "node scripts/build-nunjucks.mjs",
    "dev": "vite --host 0.0.0.0 --port 5173",
    "prebuild": "node scripts/build-nunjucks.mjs",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "format": "prettier . --write"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "autoprefixer": "^10.5.2",
    "fs-extra": "^11.3.6",
    "nunjucks": "^3.2.4",
    "postcss": "^8.5.16",
    "prettier": "^3.9.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.2",
    "vite": "^8.1.3"
  }
}
