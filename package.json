{
	"name": "pehtheme",
	"version": "2.0.0-dev",
	"private": true,
	"description": "Pehtheme static HTML template powered by Eleventy, Nunjucks, and Tailwind CSS.",
	"type": "module",
	"packageManager": "pnpm@11.8.0",
	"scripts": {
		"dev:11ty": "eleventy --serve",
		"dev:tailwind": "tailwindcss -i ./src/assets/css/app.css -o ./dist/assets/css/app.css --watch",
		"dev": "concurrently -n eleventy,tailwind -c yellow,cyan \"pnpm dev:11ty\" \"pnpm dev:tailwind\"",
		"build:11ty": "eleventy",
		"build:tailwind": "tailwindcss -i ./src/assets/css/app.css -o ./dist/assets/css/app.css --minify",
		"build": "pnpm build:11ty && pnpm build:tailwind",
		"format": "prettier . --write"
	},
	"devDependencies": {
		"@11ty/eleventy": "^3.1.6",
		"@tailwindcss/cli": "^4.3.2",
		"concurrently": "^10.0.3",
		"prettier": "^3.9.4",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"tailwindcss": "^4.3.2"
	}
}