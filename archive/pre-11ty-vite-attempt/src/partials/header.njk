<header class="border-b border-slate-200">
  <div class="mx-auto flex max-w-6xl flex-col gap-4 px-6 py-4 md:flex-row md:items-center md:justify-between">
    <a href="/" class="text-lg font-bold text-slate-900">
      {{ site.name }}
    </a>

    <nav aria-label="Primary navigation">
      <ul class="flex flex-wrap items-center gap-6 text-sm font-medium text-slate-700">
        {% for item in site.menu %}
          <li>
            <a href="{{ item.url }}" class="hover:text-slate-900">
              {{ item.label }}
            </a>
          </li>
        {% endfor %}
      </ul>
    </nav>
  </div>
</header>