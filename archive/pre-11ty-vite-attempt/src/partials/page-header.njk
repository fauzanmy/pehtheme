<section class="border-b border-slate-200 bg-slate-50">
  <div class="mx-auto max-w-6xl px-6 py-14 md:py-16">
    {% if eyebrow %}
      <p class="mb-3 text-sm font-semibold uppercase tracking-[0.16em] text-blue-600">
        {{ eyebrow }}
      </p>
    {% endif %}

    <h1 class="max-w-3xl text-3xl font-bold tracking-tight text-red-900 md:text-5xl">
      {{ heading }}
    </h1>

    {% if description %}
      <p class="mt-5 max-w-2xl text-base leading-7 text-emerald-600 md:text-lg">
        {{ description }}
      </p>
    {% endif %}
  </div>
</section>