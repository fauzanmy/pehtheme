{% extends "layouts/base.njk" %}

{% set title = "About" %}
{% set eyebrow = "About" %}
{% set heading = "A clean starting point for company profile and landing page templates." %}
{% set description = "Use this page to introduce the business, explain the design system, or document how the template is structured." %}

{% block content %}
  {% include "partials/page-header.njk" %}

  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-6 py-16">
      <div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_320px]">
        <article class="prose max-w-none prose-slate">
          <h2>Built for a reusable workflow</h2>
          <p>
            Pehtheme is now moving toward a cleaner HTML template workflow powered by Vite, Tailwind CSS, and Nunjucks. The goal is to keep the structure modular, readable, and easy to extend.
          </p>

          <p>
            Instead of repeating large HTML blocks in every page, the project now uses shared partials for header, footer, page hero sections, and reusable content sections.
          </p>

          <h3>Why this structure works well</h3>
          <ul>
            <li>It keeps multi-page templates easier to maintain.</li>
            <li>It feels familiar if you come from a WordPress theme background.</li>
            <li>It gives you a clean bridge between static HTML and future CMS integration.</li>
          </ul>
        </article>

        {% include "partials/sidebar.njk" %}
      </div>
    </div>
  </section>

  {% include "partials/sections/cta.njk" %}
{% endblock %}